{
  "name": "whathediff-desktop",
  "version": "0.1.0",
  "description": "WhatTheDiff — offline desktop app for GLB visual diffing",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --win --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.whathediff.app",
    "productName": "WhatTheDiff",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "../frontend/.next/standalone",
        "to": "app"
      },
      {
        "from": "../frontend/.next/static",
        "to": "app/.next/static"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
